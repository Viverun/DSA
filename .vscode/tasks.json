{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Current Python File (Clear Terminal)",
            "type": "shell",
            "command": "python3 \"${fileBasename}\"",
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
